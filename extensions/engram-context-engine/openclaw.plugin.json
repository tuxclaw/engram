{
  "id": "engram-context-engine",
  "kind": "context-engine",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean" },
      "workspaceRoot": { "type": "string" },
      "engramDir": { "type": "string" },
      "pythonBin": { "type": "string" },
      "topK": { "type": "integer", "minimum": 1, "maximum": 50 },
      "maxChars": { "type": "integer", "minimum": 256, "maximum": 50000 },
      "maxMemories": { "type": "integer", "minimum": 1, "maximum": 50 },
      "debug": { "type": "boolean" },
      "persistTurnTranscript": { "type": "boolean" },
      "storeAssistantMessages": { "type": "boolean" },
      "storeUserMessages": { "type": "boolean" },
      "includeSystemPromptAddition": { "type": "boolean" },
      "ownsCompaction": { "type": "boolean" }
    }
  }
}
